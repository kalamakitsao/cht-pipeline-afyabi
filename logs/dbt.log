          AND patient_sex = 'male'
    ) AS referred_missed_vaccine_male,

    NOW() AS last_updated
FROM "echis"."afyabi"."stg_immunization_status"
WHERE reported >= '2020-01-01'::date
  AND reported <  '2026-03-02'::date
  AND chp_area_id IS NOT NULL
GROUP BY chp_area_id

  );
  
