[0m09:49:06.856047 [debug] [Thread-3 (]: Began compiling node model.afyabi_analytics.stg_postnatal_care_service
[0m09:49:06.856872 [debug] [Thread-5 (]: On model.afyabi_analytics.stg_patient_sex_lookup: /* {"app": "dbt", "dbt_version": "1.10.2", "profile_name": "default", "target_name": "dev", "node_id": "model.afyabi_analytics.stg_patient_sex_lookup"} */

      
  
    

  create  table "echis"."afyabi_afyabi"."stg_patient_sex_lookup"
  
  
    as
  
  (
    

/*
  stg_patient_sex_lookup: Minimal 2-column table for denormalizing sex
  into domain staging tables.
  
  Why separate from stg_patient?
  - stg_patient is ~13GB with 67 columns
  - This table is ~2 columns × 30M rows ≈ ~1GB
  - Index-only scans on (patient_id) → sex are extremely fast
  - Joined ONCE at staging time, never at aggregation time
*/

SELECT
    uuid    AS patient_id,
    sex
FROM "echis"."afyabi"."patient_f_client"
WHERE uuid IS NOT NULL

  );
  
  
